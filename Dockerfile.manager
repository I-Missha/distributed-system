# Build stage
FROM golang:1.26-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./

RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/manager ./cmd/manager

FROM alpine:latest

WORKDIR /app

COPY --from=builder /bin/manager /app/manager

EXPOSE 8080

CMD ["/app/manager"]
